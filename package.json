{
  "name": "spec-bifrost-workspace",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --import tsx --test plugins/spec-bifrost/tests/*/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p plugins/spec-bifrost/tests/tsconfig.json",
    "check": "npm run build && npm run typecheck && npm test",
    "spec-bifrost": "node plugins/spec-bifrost/dist/cli/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
